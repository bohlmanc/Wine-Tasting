require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

ENV['RCT_NEW_ARCH_ENABLED'] = podfile_properties['newArchEnabled'] == 'true' ? '1' : '0'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] = podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']

platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'
install! 'cocoapods',
  :deterministic_uuids => false

prepare_react_native_project!

target 'WinePocketPal' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => podfile_properties['apple.ccacheEnabled'] == 'true',
    )

    # fmt's version threshold for the Apple Clang consteval bug is too low —
    # it only disables consteval for < Apple Clang 14, but the bug persists in 15/16.
    # Patch base.h to disable consteval for all Apple Clang builds.
    fmt_base = "#{installer.sandbox.root}/fmt/include/fmt/base.h"
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(
        '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        '#elif defined(__apple_build_version__)'
      ).gsub(
        '#  define FMT_USE_CONSTEVAL 0  // consteval is broken in Apple clang < 14.',
        '#  define FMT_USE_CONSTEVAL 0  // consteval is broken in Apple clang.'
      )
      File.write(fmt_base, patched) if patched != content
    end

    # Patches for project paths containing spaces ("Wine App").
    # All three patterns use an unquoted variable inside `bash/sh -c "..."` or
    # an unquoted `$1` / backtick, which the shell word-splits on the space.
    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        next unless phase.respond_to?(:shell_script)

        # [CP-User] Generate Specs (ReactCodegen):
        #   /bin/sh -c "$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT"  →  /bin/sh "$W..." "$S..."
        if phase.respond_to?(:name) && phase.name == '[CP-User] Generate Specs'
          phase.shell_script = phase.shell_script.gsub(
            '/bin/sh -c "$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT"',
            '/bin/sh "$WITH_ENVIRONMENT" "$SCRIPT_PHASES_SCRIPT"'
          )
        end

        # [CP-User] Generate app.config for prebuilt Constants.manifest (EXConstants):
        #   bash -l -c "$PODS_TARGET_SRCROOT/..."  →  bash -l "$PODS_TARGET_SRCROOT/..."
        if phase.respond_to?(:name) && phase.name == '[CP-User] Generate app.config for prebuilt Constants.manifest'
          phase.shell_script = phase.shell_script.gsub(
            'bash -l -c "$PODS_TARGET_SRCROOT/../scripts/get-app-config-ios.sh"',
            'bash -l "$PODS_TARGET_SRCROOT/../scripts/get-app-config-ios.sh"'
          )
        end
      end
    end

    # Yoga does `#undef __cpp_consteval` which Xcode 26's Clang treats as an error
    # under -Werror,-Wbuiltin-macro-redefined. Suppress the warning for Yoga only.
    installer.pods_project.targets.each do |target|
      if target.name == 'Yoga'
        target.build_configurations.each do |config|
          flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{flags} -Wno-builtin-macro-redefined"
        end
      end
    end

    # Save all Pods project changes once, after all modifications above.
    installer.pods_project.save

    # Fix the main app's "Bundle React Native code and images" build phase.
    # It uses an unquoted backtick substitution:
    #   `"$NODE_BINARY" --print "...react-native-xcode.sh"`
    # which word-splits on the space in "Wine App". Replace with a quoted variable.
    installer.aggregate_targets.each do |aggregate_target|
      user_project = aggregate_target.user_project
      next unless user_project
      user_project.targets.each do |target|
        target.build_phases.each do |phase|
          next unless phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
          next unless phase.name == 'Bundle React Native code and images'
          old_line = "`\"$NODE_BINARY\" --print \"require('path').dirname(require.resolve('react-native/package.json')) + '/scripts/react-native-xcode.sh'\"`"
          new_line = "REACT_NATIVE_XCODE_SH=\"$(\"$NODE_BINARY\" --print \"require('path').dirname(require.resolve('react-native/package.json')) + '/scripts/react-native-xcode.sh'\")\"\n\"$REACT_NATIVE_XCODE_SH\""
          phase.shell_script = phase.shell_script.gsub(old_line, new_line)
        end
      end
      user_project.save
    end

    # This is necessary for Xcode 14, because it signs resource bundles by default
    # when building for devices.
    installer.target_installation_results.pod_target_installation_results
      .each do |pod_name, target_installation_result|
      target_installation_result.resource_bundle_targets.each do |resource_bundle_target|
        resource_bundle_target.build_configurations.each do |config|
          config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        end
      end
    end
  end
end
